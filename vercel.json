{
  "version": 2,
  "name": "food-delivery-smartsoko",
  "builds": [
    {
      "src": "web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/customer",
      "dest": "/web/customer.html"
    },
    {
      "src": "/supabase",
      "dest": "/web/supabase.html"
    },
    {
      "src": "/test-supabase",
      "dest": "/web/test-supabase.html"
    },
    {
      "src": "/restaurant",
      "dest": "/web/restaurant.html"
    },
    {
      "src": "/",
      "dest": "/web/index.html"
    }
  ],
  "headers": [
    {
      "source": "/web/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
