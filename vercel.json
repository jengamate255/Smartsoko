{
  "version": 2,
  "name": "food-delivery-smartsoko",
  "builds": [
    {
      "src": "web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/customer",
      "dest": "/web/customer.html"
    },
    {
      "src": "/home",
      "dest": "/web/home.html"
    },
    {
      "src": "/discovery",
      "dest": "/web/discovery.html"
    },
    {
      "src": "/product",
      "dest": "/web/product.html"
    },
    {
      "src": "/cart",
      "dest": "/web/cart.html"
    },
    {
      "src": "/checkout",
      "dest": "/web/smartsoko-checkout.html"
    },
    {
      "src": "/tracking",
      "dest": "/web/index.html"
    },
    {
      "src": "/chat",
      "dest": "/web/chat.html"
    },
    {
      "src": "/profile",
      "dest": "/web/profile.html"
    },
    {
      "src": "/driver",
      "dest": "/web/driver.html"
    },
    {
      "src": "/merchant",
      "dest": "/web/merchant.html"
    },
    {
      "src": "/seller",
      "dest": "/web/seller.html"
    },
    {
      "src": "/restaurant",
      "dest": "/web/restaurant.html"
    },
    {
      "src": "/admin",
      "dest": "/web/supabase.html"
    },
    {
      "src": "/smartsoko",
      "dest": "/web/smartsoko-home.html"
    },
    {
      "src": "/smartsoko/products",
      "dest": "/web/smartsoko-products.html"
    },
    {
      "src": "/smartsoko/vendor",
      "dest": "/web/smartsoko-vendor.html"
    },
    {
      "src": "/smartsoko/cart",
      "dest": "/web/smartsoko-cart.html"
    },
    {
      "src": "/smartsoko/checkout",
      "dest": "/web/smartsoko-checkout.html"
    },
    {
      "src": "/supabase",
      "dest": "/web/supabase.html"
    },
    {
      "src": "/test-supabase",
      "dest": "/web/test-supabase.html"
    },
    {
      "src": "/test/api",
      "dest": "/web/test-api-integration.html"
    },
    {
      "src": "/404",
      "dest": "/web/404.html"
    },
    {
      "src": "/",
      "dest": "/web/main.html"
    },
    {
      "src": "/orders",
      "dest": "/web/orders.html"
    },
    {
      "src": "/admin-dashboard",
      "dest": "/web/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/web/404.html"
    }
  ],
  "headers": [
    {
      "source": "/web/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
